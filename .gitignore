# Root .gitignore for youtub-transcription project

# Node / Frontend
node_modules/
frontend/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
frontend/.next/
/out/
/build/
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*
.vercel
*.tsbuildinfo
next-env.d.ts

# Python / Backend (scoped to backend/ so frontend/src/lib is not ignored)
backend/__pycache__/
backend/**/*.py[cod]
backend/**/*$py.class
backend/**/*.so
backend/.Python
backend/build/
backend/develop-eggs/
backend/dist/
backend/downloads/
backend/eggs/
backend/.eggs/
backend/lib/
backend/lib64/
backend/parts/
backend/sdist/
backend/var/
backend/wheels/
backend/share/python-wheels/
backend/**/*.egg-info/
backend/.installed.cfg
backend/**/*.egg
backend/MANIFEST
backend/**/*.manifest
backend/**/*.spec
backend/pip-log.txt
backend/pip-delete-this-directory.txt
backend/htmlcov/
backend/.cache
backend/.noseresults
backend/.pytest_cache/
backend/.hypothesis/
backend/.run
backend/**/*.mo
backend/**/*.pot
backend/**/*.log
backend/local_settings.py
backend/db.sqlite3
backend/db.sqlite3-journal
backend/instance/
backend/.webassets-cache
backend/.scrapy
backend/docs/_build/
backend/.pybuilder/
backend/target/
backend/.ipynb_checkpoints
backend/profile_default/
backend/ipython_config.py
backend/.venv/
backend/venv/
backend/ENV/
backend/env.bak/
backend/venv.bak/
backend/.spyderproject
backend/.spyproject
backend/.ropeproject
backend/site/
backend/.mypy_cache/
backend/.dmypy.json
backend/dmypy.json
backend/.pyre/
backend/.pytype/
backend/cython_debug/

# Also ignore venv at repo root if created there
.venv/
venv/
